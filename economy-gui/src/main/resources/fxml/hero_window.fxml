<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="10" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="pl.psi.gui.hero.HeroWindowController" prefWidth="300" prefHeight="400">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Hero Statistics" style="-fx-font-weight: bold; -fx-font-size: 16px;"/>

    <GridPane vgap="5" hgap="10">
        <columnConstraints>
            <ColumnConstraints minWidth="100"/>
            <ColumnConstraints hgrow="ALWAYS"/>
        </columnConstraints>

        <Label text="Level:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <Label fx:id="levelLabel" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Experience:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <Label fx:id="experienceLabel" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Attack:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <Label fx:id="attackLabel" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="Defense:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <Label fx:id="defenseLabel" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

        <Label text="Power:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <Label fx:id="powerLabel" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

        <Label text="Knowledge:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
        <Label fx:id="knowledgeLabel" GridPane.rowIndex="5" GridPane.columnIndex="1"/>

        <Label text="Movement:" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
        <Label fx:id="movementLabel" GridPane.rowIndex="6" GridPane.columnIndex="1"/>
    </GridPane>

    <Separator/>

    <Label text="Skills" style="-fx-font-weight: bold;"/>
    <ListView fx:id="skillsListView" VBox.vgrow="ALWAYS"/>

</VBox>
